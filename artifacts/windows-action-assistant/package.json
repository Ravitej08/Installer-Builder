{
  "name": "@workspace/windows-action-assistant",
  "version": "1.0.0",
  "description": "A lightweight Windows assistant for actions, settings, and problem-solving using natural language",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "electron:build": "pnpm run build && electron-builder --win --x64",
    "electron:dev": "cross-env NODE_ENV=development electron electron/main.js"
  },
  "devDependencies": {
    "@replit/vite-plugin-cartographer": "catalog:",
    "@replit/vite-plugin-dev-banner": "catalog:",
    "@replit/vite-plugin-runtime-error-modal": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "cross-env": "^7.0.3",
    "electron": "^35.2.0",
    "electron-builder": "^25.1.8",
    "framer-motion": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "vite": "catalog:"
  },
  "build": {
    "appId": "com.windowsactionassistant.app",
    "productName": "Windows Action Assistant",
    "copyright": "Copyright 2025 Windows Action Assistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/public/**/*",
      "electron/**/*",
      "data/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Windows Action Assistant",
      "installerIcon": "public/icon.png",
      "uninstallerIcon": "public/icon.png"
    }
  }
}

  {
    "id": "brightness_up",
    "intent": "brightness_up",
    "keywords": ["brightness up", "increase brightness", "brighter", "screen too dark", "turn up brightness"],
    "aliases": [],
    "description": "Increase screen brightness",
    "safeAutoExecute": true,
    "actions": [
      { "type": "powershell", "value": "(Get-WmiObject -Namespace root/WMI -Class WmiMonitorBrightnessMethods).WmiSetBrightness(1,[Math]::Min(100, (Get-WmiObject -Namespace root/WMI -Class WmiMonitorBrightness).CurrentBrightness + 20))" }
    ]
  },
  {
